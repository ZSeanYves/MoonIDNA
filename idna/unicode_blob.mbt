fn unicode_data_byte_at(offset : Int) -> Byte {
  if offset < 65536 {
    return unicode_data_blob_0[offset - 0]
  }
  if offset < 131072 {
    return unicode_data_blob_1[offset - 65536]
  }
  if offset < 196608 {
    return unicode_data_blob_2[offset - 131072]
  }
  if offset < 262144 {
    return unicode_data_blob_3[offset - 196608]
  }
  if offset < 327680 {
    return unicode_data_blob_4[offset - 262144]
  }
  unicode_data_blob_5[offset - 327680]
}
